{
    "builds": [
        { "src": "app.py", "use": "@vercel/python" },
        { "src": "public/**", "use": "@vercel/static" }
    ],
    "routes": [
        { "src": "/api/(.*)", "dest": "app.py" },
        { "src": "/resource/(.*)", "dest": "public/resource/$1" },
        { "src": "/(.*)", "dest": "public/index.html" }
    ]
}
